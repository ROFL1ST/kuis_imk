# ════════════════════════════════════════════════════
# QuizzApp Indo — Environment Variables
# ════════════════════════════════════════════════════
#
# Copy this file to .env.local for local development.
# .env.local is git-ignored and safe for local config.
#
# SECURITY RULE (Vite docs):
#   Only VITE_* vars are exposed to the browser bundle.
#   NEVER put secret API keys in VITE_* variables.
#   Secret keys belong on the BACKEND server only.
# ════════════════════════════════════════════════════

# Backend API base URL
# In dev, Vite proxy rewrites /api → this URL automatically.
# In production, point this to your real backend domain.
VITE_API_URL=http://localhost:8080

# ── DO NOT ADD THESE HERE ────────────────────────────
# VITE_API_KEY=...       ← WRONG: exposes key to browser
# VITE_SBERT_KEY=...     ← WRONG: exposes key to browser
#
# Instead, add secrets to your BACKEND .env:
#   SBERT_API_KEY=sk-...
#   JWT_SECRET=...
# ────────────────────────────────────────────────────
